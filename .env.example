# ============================
# SolveMate Environment Variables
# ============================
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control

# MongoDB Atlas Connection String
DB_PATH=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority

# Session Secret (generate a random string)
SESSION_SECRET=your-super-secret-session-key-change-me

# Server Port
PORT=3000

# Node Environment (development | production | test)
NODE_ENV=development

# CORS Origin (use * for development, specific domain for production)
CORS_ORIGIN=*

# Log Level (error | warn | info | debug)
LOG_LEVEL=info
