    <form action="/filter" method="POST" class="row g-3 mb-4">
      <div class="col-md-4">
        <label for="dif" class="form-label fw-bold small text-secondary">Difficulty</label>
        <select name="difficulty" id="dif" class="form-select">
          <option value="All" <%= difficulty === 'All' ? 'selected' : '' %>>All</option>
          <option value="EASY" <%= difficulty.toUpperCase() === 'EASY' ? 'selected' : '' %>>EASY</option>
          <option value="medium" <%= difficulty.toLowerCase() === 'medium' ? 'selected' : '' %>>medium</option>
          <option value="hard" <%= difficulty.toLowerCase() === 'hard' ? 'selected' : '' %>>hard</option>
        </select>
      </div>
      <div class="col-md-4">
        <label for="company" class="form-label fw-bold small text-secondary">Company</label>
        <select name="company" id="company" class="form-select">
          <option value="All" <%= company === 'All' ? 'selected' : '' %>>All</option>
          <% companies.forEach(c => { %>
            <option value="<%= c %>" <%= company.toLowerCase() === c.toLowerCase() ? 'selected' : '' %>><%= c %></option>
          <% }) %>
        </select>
      </div>
      <div class="col-md-4">
        <label for="tag" class="form-label fw-bold small text-secondary">Topic Tag</label>
        <select name="tag" id="tag" class="form-select">
          <option value="All" <%= tag === 'All' ? 'selected' : '' %>>All</option>
          <% tags.forEach(t => { %>
            <option value="<%= t %>" <%= tag.toLowerCase() === t.toLowerCase() ? 'selected' : '' %>><%= t %></option>
          <% }) %>
        </select>
      </div>
      <div class="col-12 text-end">
        <button type="submit" class="btn btn-primary">Filter</button>
        <button type="button" class="btn btn-secondary" onclick="document.location.href='/home'">Clear Filter</button>
      </div>
    </form>